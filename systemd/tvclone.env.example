# Copy to /etc/tvclone/tvclone.env and edit for the target machine.
PORT=4800
TVCLONE_SERVICE=tvclone.service
ORGANIZER_SERVICE=tvclone-organizer.service
DOCKER_MEDIA_SERVICE=docker-media.service
TVCLONE_REQUIRED_MEDIA_DIRS=/mnt/media/Movies,/mnt/media/TV
TVCLONE_DOWNLOAD_DIR=/mnt/media/Share
TVCLONE_DOCKER_CONTAINERS=gluetun,qbittorrent
TVCLONE_BACKUP_ROOT=/var/backups/tvclone
ORGANIZER_LOG=/opt/tvclone/media-organizer/media-organizer.log
QBT_URL=http://127.0.0.1:8080
QBT_USER=
QBT_PASS=
OMDB_API_KEY=
ENABLE_SPRITES=1
PROBE_CONCURRENCY=2
MAX_TRANSCODE_SESSIONS=2
FFMPEG_TRANSCODE_THREADS=2
